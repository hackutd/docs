{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "HackUTD Docs",
  "colors": {
    "primary": "#FF491B",
    "light": "#FFA21F",
    "dark": "#FF005E"
  },
  "appearance": {
    "default": "light"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index"
        ]
      },
      {
        "group": "Projects",
        "pages": [
          "harp",
          "technical-documentation"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/hackutd"
      }
    ],
    "primary": {
      "type": "button",
      "label": "HackUTD",
      "href": "https://hackutd.co"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/hackutd",
      "github": "https://github.com/hackutd",
      "instagram": "https://instagram.com/hackutd"
    }
  }
}
